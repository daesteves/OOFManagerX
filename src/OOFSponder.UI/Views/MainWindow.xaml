<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OOFSponder.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OOFSponder.UI.Views"
    Title="OOFSponder - Out of Office Manager">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8D4;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock Text="OOFSponder" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                <PersonPicture Width="32" Height="32" DisplayName="{x:Bind ViewModel.UserDisplayName, Mode=OneWay}"/>
                <TextBlock Text="{x:Bind ViewModel.UserDisplayName, Mode=OneWay}" VerticalAlignment="Center"/>
                <Button Content="Sign In" Command="{x:Bind ViewModel.SignInCommand}" 
                        Visibility="{x:Bind ViewModel.IsNotSignedIn, Mode=OneWay}"/>
                <Button Content="Sign Out" Command="{x:Bind ViewModel.SignOutCommand}"
                        Visibility="{x:Bind ViewModel.IsSignedIn, Mode=OneWay}"/>
                
                <!-- Settings Menu -->
                <DropDownButton Content="&#xE712;" FontFamily="Segoe MDL2 Assets" Padding="8">
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <ToggleMenuFlyoutItem x:Name="StartWithWindowsToggle" Text="Start with Windows" 
                                                  Click="StartWithWindows_Click"
                                                  ToolTipService.ToolTip="Automatically start OOFSponder when you log in to Windows">
                                <ToggleMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE7E8;"/>
                                </ToggleMenuFlyoutItem.Icon>
                            </ToggleMenuFlyoutItem>
                            <ToggleMenuFlyoutItem x:Name="StartMinimizedToggle" Text="Start Minimized" 
                                                  Click="StartMinimized_Click"
                                                  ToolTipService.ToolTip="Start OOFSponder minimized to system tray">
                                <ToggleMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE921;"/>
                                </ToggleMenuFlyoutItem.Icon>
                            </ToggleMenuFlyoutItem>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="View Logs" Click="ViewLogs_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE7C3;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Open Logs Folder" Click="OpenLogsFolder_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="About" Click="About_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE946;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="Exit" Click="Exit_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE7E8;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24">
                
                <!-- Work Schedule -->
                <StackPanel>
                    <TextBlock Text="📅 Work Schedule" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.WorkingDays}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding DayName}" 
                                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        
                                        <CheckBox Grid.Column="1" Content="Off Work" 
                                                  IsChecked="{Binding IsOffWork, Mode=TwoWay}"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                                    Opacity="{Binding IsOffWork, Converter={StaticResource BoolToOpacityInverseConverter}}">
                                            <TextBox Text="{Binding StartTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     PlaceholderText="09:00" Width="70" 
                                                     IsEnabled="{Binding IsNotOffWork}"
                                                     TextAlignment="Center"/>
                                            <TextBlock Text="to" VerticalAlignment="Center" Margin="4,0"/>
                                            <TextBox Text="{Binding EndTimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     PlaceholderText="17:00" Width="70"
                                                     IsEnabled="{Binding IsNotOffWork}"
                                                     TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Border>
                </StackPanel>

                <!-- OOF Messages -->
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="📧 OOF Messages" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        
                        <!-- Templates -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                            <DropDownButton Content="Templates">
                                <DropDownButton.Flyout>
                                    <MenuFlyout x:Name="TemplatesFlyout" Opening="TemplatesFlyout_Opening">
                                        <MenuFlyoutItem Text="Save as Template..." Click="SaveAsTemplate_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74E;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <!-- Templates will be added dynamically -->
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <RadioButton Content="Primary" GroupName="OOFType"
                                         IsChecked="{x:Bind ViewModel.IsPrimaryOOFSelected, Mode=TwoWay}"/>
                            <RadioButton Content="Extended" GroupName="OOFType"
                                         IsChecked="{x:Bind ViewModel.IsExtendedOOFSelected, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Extended OOF Date Picker -->
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12"
                                Visibility="{x:Bind ViewModel.IsExtendedOOFSelected, Mode=OneWay}">
                        <TextBlock Text="Resume normal schedule on:" VerticalAlignment="Center"/>
                        <CalendarDatePicker Date="{x:Bind ViewModel.ExtendedOOFEndDate, Mode=TwoWay}" 
                                            PlaceholderText="Select date"/>
                    </StackPanel>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="16">
                            <!-- Internal Message -->
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Internal Message (sent to colleagues)" 
                                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <Button Grid.Column="1" Click="PreviewInternal_Click"
                                            ToolTipService.ToolTip="Preview how this message will appear">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8A1;" FontSize="14"/>
                                            <TextBlock Text="Preview"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBox Text="{x:Bind ViewModel.InternalMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                                         PlaceholderText="Enter your internal OOF message..."/>
                            </StackPanel>
                            
                            <!-- External Message -->
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="External Message (sent to outside contacts)" 
                                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{x:Bind ViewModel.ExternalAudienceOptions}"
                                              SelectedIndex="{x:Bind ViewModel.SelectedExternalAudienceIndex, Mode=TwoWay}"
                                              Width="150" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Click="PreviewExternal_Click"
                                            ToolTipService.ToolTip="Preview how this message will appear">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8A1;" FontSize="14"/>
                                            <TextBlock Text="Preview"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBox Text="{x:Bind ViewModel.ExternalMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                                         PlaceholderText="Enter your external OOF message..."/>
                            </StackPanel>

                            <!-- Markdown hint -->
                            <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7" Margin="0,8,0,0">
                                <FontIcon Glyph="&#xE946;" FontSize="12"/>
                                <TextBlock Text="Supports" FontSize="12"/>
                                <HyperlinkButton Content="Markdown" 
                                                 NavigateUri="https://www.markdownguide.org/basic-syntax/" 
                                                 Padding="0" FontSize="12"/>
                                <TextBlock Text=": **bold** *italic* ~~strike~~ [link](url) # headings, lists, > quotes" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Monitoring Toggle -->
            <ToggleButton x:Name="MonitoringToggle" 
                          Grid.Column="0"
                          IsChecked="{x:Bind ViewModel.IsMonitoringEnabled, Mode=TwoWay}"
                          Click="MonitoringToggle_Click"
                          Padding="12,8"
                          ToolTipService.ToolTip="When enabled, OOFSponder automatically monitors your schedule and sets Out of Office replies in Microsoft 365. Disable to stop automatic OOF management.">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="{x:Bind ViewModel.MonitoringIcon, Mode=OneWay}" FontSize="16"/>
                    <TextBlock Text="{x:Bind ViewModel.MonitoringStatusText, Mode=OneWay}"/>
                </StackPanel>
            </ToggleButton>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0,0,0">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                              Width="20" Height="20"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Button Grid.Column="2" Content="💾 Save Settings" Command="{x:Bind ViewModel.SaveSettingsCommand}"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
